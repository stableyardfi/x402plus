# Required — your EVM wallet address to receive payments
PAY_TO=0xYourEVMAddress

# Optional — default EVM chain (default: base)
# Options: ethereum, base, polygon, arbitrum, optimism, base-sepolia, polygon-amoy
NETWORK=base

# Optional — custom facilitator URL (default: https://facilitator.stableyard.fi)
# FACILITATOR_URL=https://facilitator.stableyard.fi

# Optional — enable Solana payments
# SOLANA_PAY_TO=YourSolanaAddress
# SOLANA_NETWORK=solana-devnet

# Optional — enable Movement payments
# MOVEMENT_PAY_TO=0xYourMovementAddress
# MOVEMENT_NETWORK=movement

# Optional — server port (default: 4000)
# PORT=4000
