{
  "name": "@stableyard/x402plus",
  "version": "2.0.0",
  "description": "x402plus — HTTP 402 payments with multi-chain support (EVM, Solana, Movement) and intent-based payments via Stableyard GRID ID",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "sideEffects": false,
  "license": "Apache-2.0",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js",
      "require": "./dist/middleware.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.js"
    },
    "./facilitator": {
      "types": "./dist/facilitator.d.ts",
      "import": "./dist/facilitator.js",
      "require": "./dist/facilitator.js"
    }
  },
  "keywords": [
    "x402",
    "x402plus",
    "http-402",
    "payment",
    "crypto",
    "usdc",
    "evm",
    "solana",
    "movement",
    "api-payments",
    "middleware",
    "stableyard"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "axios": "^1.7.7"
  },
  "peerDependencies": {
    "express": "^4 || ^5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.11",
    "typescript": "^5.6.3"
  }
}
